# ── Local Development .env ──────────────────────────────────────────────────
# Copy this to backend/.env for local development (python manage.py runserver)

SECRET_KEY=dev-secret-key-change-this-in-production-use-50-plus-chars-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (local PostgreSQL) ─────────────────────────────────────────────
# Run: createdb cahayo  (or use postgres app on Mac)
DB_NAME=cahayo
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Redis (local) ───────────────────────────────────────────────────────────
# Install: brew install redis && brew services start redis
REDIS_URL=redis://localhost:6379/0

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── M-Pesa (sandbox - get free credentials at developer.safaricom.co.ke) ───
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your-sandbox-consumer-key
MPESA_CONSUMER_SECRET=your-sandbox-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/mpesa/callback/
MPESA_CONFIRMATION_URL=https://your-ngrok-url.ngrok.io/api/mpesa/c2b/confirm/
MPESA_VALIDATION_URL=https://your-ngrok-url.ngrok.io/api/mpesa/c2b/validate/

# ── Africa's Talking (sandbox SMS) ─────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your-at-api-key

# ── Email (use console backend in dev, no real SMTP needed) ────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=test@example.com
EMAIL_HOST_PASSWORD=test
DEFAULT_FROM_EMAIL=Cahayo Dev <dev@cahayo.local>
