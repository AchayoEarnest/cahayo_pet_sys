# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-50-chars
DEBUG=False
ALLOWED_HOSTS=cahayo.co.ke,www.cahayo.co.ke,localhost

# ─── Database ──────────────────────────────────────────────────────────────────
DB_NAME=cahayo
DB_USER=cahayo
DB_PASSWORD=strong-database-password-here
DB_HOST=db
DB_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://cahayo.co.ke,https://www.cahayo.co.ke

# ─── M-Pesa Daraja API ─────────────────────────────────────────────────────────
# Get these from https://developer.safaricom.co.ke
MPESA_ENVIRONMENT=sandbox             # sandbox | production
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379               # Paybill or Till number
MPESA_PASSKEY=your-passkey           # From Daraja portal
MPESA_CALLBACK_URL=https://cahayo.co.ke/api/mpesa/callback/
MPESA_CONFIRMATION_URL=https://cahayo.co.ke/api/mpesa/c2b/confirm/
MPESA_VALIDATION_URL=https://cahayo.co.ke/api/mpesa/c2b/validate/

# ─── Africa's Talking (SMS) ────────────────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your-at-api-key

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@cahayo.co.ke
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Cahayo FMS <noreply@cahayo.co.ke>

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://cahayo.co.ke/api
NEXT_PUBLIC_APP_NAME=Cahayo FMS
NEXT_PUBLIC_APP_VERSION=1.0.0
